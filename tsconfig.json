{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["chrome"],
    "jsx": "react-jsx"
  },
  "include": [
    "apps/extension/src/**/*.ts",
    "apps/extension/src/**/*.tsx",
    "packages/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "tools"
  ]
}
