{
  "name": "kotomi-browser-extension",
  "version": "0.1.0",
  "private": true,
  "description": "Chrome extension for capturing browser tab audio and transcribing it through Kotomi.",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run test:export-serializers && npm run test:storage-persistence",
    "test:all": "npm run check && npm run test:mock-transcriber",
    "test:mock-transcriber": "npx tsx tools/mock-transcriber/tests/transcriber-smoke.test.ts",
    "test:real-transcriber": "npx tsx tools/real-transcriber/tests/real-transcriber-smoke.test.ts",
    "test:real-asr-e2e": "npx tsx tools/real-transcriber/tests/real-asr-e2e.test.ts",
    "test:export-serializers": "npx tsx packages/transcript-core/tests/export-serializers.test.ts",
    "test:storage-persistence": "npx tsx packages/transcript-core/tests/storage-persistence.test.ts",
    "mock-transcriber": "npm --prefix tools/mock-transcriber start",
    "real-transcriber": "npm --prefix tools/real-transcriber run start:mock",
    "real-transcriber:faster-whisper": "npm --prefix tools/real-transcriber run start:faster-whisper",
    "build:extension": "npx tsx apps/extension/build.ts"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.43",
    "@types/node": "^25.9.2",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.3"
  },
  "allowScripts": {
    "esbuild@0.28.0": true
  }
}
