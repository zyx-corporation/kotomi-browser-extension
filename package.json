{
  "name": "kotomi-browser-extension",
  "version": "0.1.0",
  "private": true,
  "description": "Chrome extension for capturing browser tab audio and transcribing it through Kotomi.",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test:mock-transcriber": "npx tsx tools/mock-transcriber/tests/transcriber-smoke.test.ts",
    "mock-transcriber": "npm --prefix tools/mock-transcriber start"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.43",
    "typescript": "^6.0.3"
  }
}
